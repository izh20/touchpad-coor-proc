#!/bin/bash
# RunFingerViewer.app executable - accepts dragged files as arguments

# 计算项目根（假设 .app 放在项目根目录）
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
LOG="$PROJECT_DIR/run_finger_viewer_app.log"

echo "=== RunFingerViewer $(date) ===" >> "$LOG"
echo "PROJECT_DIR=$PROJECT_DIR" >> "$LOG"

# 选择 Python 解释器
if command -v python3 >/dev/null 2>&1; then
  PY=$(command -v python3)
elif [ -x "/usr/bin/python3" ]; then
  PY=/usr/bin/python3
elif [ -x "/opt/homebrew/bin/python3" ]; then
  PY=/opt/homebrew/bin/python3
else
  PY="/usr/bin/env python3"
fi

echo "PY=$PY" >> "$LOG"

if [ $# -eq 0 ]; then
  echo "No input files provided." >> "$LOG"
  /usr/bin/osascript -e 'display dialog "请把数据文件（例如 1.txt）拖放到此应用上运行。" buttons {"OK"} default button "OK"'
  exit 1
fi

# Run each file in background and log output
for f in "$@"; do
  echo "Running: $f" >> "$LOG"
  "$PY" "$PROJECT_DIR/finger_trajectory_realtime.py" "$f" >> "$LOG" 2>&1 &
done

exit 0
